<Window x:Class="WPFCalc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFCalc"
        mc:Ignorable="d"
        Title="Калькулятор" Height="600" Width="500">
    <Grid x:Name="MainLayout">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="90"></RowDefinition>
            <RowDefinition Height="90"></RowDefinition>
            <RowDefinition Height="90"></RowDefinition>
            <RowDefinition Height="90"></RowDefinition>
            <RowDefinition Height="90"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Vertical" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4">
            <TextBox x:Name="tbCommandHistory" TextAlignment="Right" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" FontSize="40" FontWeight="Normal"/>
            <TextBox x:Name="tbCommand" TextAlignment="Right" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" FontSize="40" FontWeight="Normal"/>
        </StackPanel>
        <Button x:Name="one" Grid.Column="0" Grid.Row="2" Content="1" FontSize="36"/>
        <Button x:Name="two" Grid.Column="1" Grid.Row="2" Content="2" FontSize="36"/>
        <Button x:Name="free" Grid.Column="2" Grid.Row="2" Content="3" FontSize="36"/>
        <Button x:Name="four" Grid.Column="0" Grid.Row="3" Content="4" FontSize="36"/>
        <Button x:Name="five" Grid.Column="1" Grid.Row="3" Content="5" FontSize="36"/>
        <Button x:Name="six" Grid.Column="2" Grid.Row="3" Content="6" FontSize="36"/>
        <Button x:Name="seven" Grid.Column="0" Grid.Row="4" Content="7" FontSize="36"/>
        <Button x:Name="eight" Grid.Column="1" Grid.Row="4" Content="8" FontSize="36"/>
        <Button x:Name="nine" Grid.Column="2" Grid.Row="4" Content="9" FontSize="36"/>
        <Button x:Name="C" Grid.Column="0" Grid.Row="5" Content="C" FontSize="36"/>
        <Button x:Name="null" Grid.Column="1" Grid.Row="5" Content="0" FontSize="36"/>
        <Button x:Name="dot" Grid.Column="2" Grid.Row="5" Content="." FontSize="36"/>
        <Button x:Name="smooth" Grid.Column="3" Grid.Row="5" Content="=" FontSize="36"/>
        <Button x:Name="plus" Grid.Column="3" Grid.Row="4" Content="+" FontSize="36"/>
        <Button x:Name="minus" Grid.Column="3" Grid.Row="3" Content="-" FontSize="36"/>
        <Button x:Name="multiply" Grid.Column="3" Grid.Row="2" Content="*" FontSize="36"/>
        <Button x:Name="division" Grid.Column="3" Grid.Row="1" Content="/" FontSize="36"/>
        <Button x:Name="RaistToPower" Grid.Column="2" Grid.Row="1" Content="^" FontSize="36"/>
        <Button x:Name="RightParenthesis" Grid.Column="1" Grid.Row="1" Content=")" FontSize="36"/>
        <Button x:Name="LeftParenthesis" Grid.Column="0" Grid.Row="1" Content="(" FontSize="36"/>
    </Grid>
</Window>
